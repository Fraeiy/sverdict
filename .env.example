# ─── LOCAL DEV ───────────────────────────────────────────────────
VITE_WALLET_URL=https://sphere.unicity.network

# Local dev uses REST API (npm run dev:full starts backend on :8787)
# No Supabase vars needed for local dev.

# ─── PRODUCTION (Vercel + Supabase) ──────────────────────────────
# See PRODUCTION.md and .env.production.example
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_TREASURY_ADDRESS=DIRECT://your-treasury-address

# ─── TREASURY AGENT (autonomous withdrawal fulfillment) ───────────
# Run: npm run treasury:worker:loop
# Or use GitHub Actions workflow .github/workflows/treasury-agent.yml
# TREASURY_MNEMONIC=your twelve word phrase for @sphere-predict
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SPHERE_ORACLE_API_KEY=sk_...  # testnet2 gateway — see sphere-sdk README
# MAX_AUTO_WITHDRAWAL_UCT=500
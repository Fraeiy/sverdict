# ─── LOCAL DEV ───────────────────────────────────────────────────
VITE_WALLET_URL=https://sphere.unicity.network

# ─── PRODUCTION (Vercel + Supabase) ──────────────────────────────
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_TREASURY_ADDRESS=@sphere-predict

# ─── TREASURY AGENT (npm run treasury:worker:*) ────────────────
# Worker auto-loads this file + .env.production.local
# SUPABASE_URL is optional if VITE_SUPABASE_URL is set above
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # required for status/dry-run/live
# TREASURY_MNEMONIC=twelve word phrase             # only for live sends
# SPHERE_ORACLE_API_KEY=sk_...                     # optional testnet2 gateway key
# MAX_AUTO_WITHDRAWAL_UCT=500

# ─── EXTERNAL TREASURY CRON (npm run treasury:trigger) ─────────
# Classic PAT with repo scope — triggers GitHub repository_dispatch every 10 min
# GITHUB_PAT=ghp_...
# Also add the same value as GitHub repo secret TREASURY_TRIGGER_PAT (for treasury-dispatch-cron workflow)

# ─── AI SUGGESTIONS (Admin UI + optional CLI) ───────────────────
# Add to Supabase Edge Function secrets (platform) for Admin → AI suggestions:
# XAI_API_KEY=xai-...   # https://console.x.ai
# XAI_MODEL=grok-4.5    # optional
# CLI (same key in .env): npm run market:agent:propose | market:agent:settle
# ─── LOCAL DEV ───────────────────────────────────────────────────
VITE_WALLET_URL=https://sphere.unicity.network

# ─── PRODUCTION (Vercel + Supabase) ──────────────────────────────
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_TREASURY_ADDRESS=@sphere-predict
# VITE_SITE_URL=https://sverdict.vercel.app
# SITE_URL=https://sverdict.vercel.app
# OPENROUTER_SITE_URL=https://sverdict.vercel.app

# ─── TREASURY AGENT (npm run treasury:worker:*) ────────────────
# Worker auto-loads this file + .env.production.local
# SUPABASE_URL is optional if VITE_SUPABASE_URL is set above
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # required for status/dry-run/live
# TREASURY_MNEMONIC=twelve word phrase             # only for live sends
# SPHERE_ORACLE_API_KEY=sk_...                     # optional testnet2 gateway key
# MAX_AUTO_WITHDRAWAL_UCT=500
# TREASURY_CONSOLIDATE_MIN_COINS=2   # merge when treasury holds 2+ UCT coins
# TREASURY_CONSOLIDATE_MAX_OPS=5     # per worker pass
# TREASURY_PREWITHDRAW_MAX_OPS=8     # extra merges before each withdrawal send

# ─── TREASURY CRON (no PC — add to Vercel env, not VITE_*) ─────
# GITHUB_PAT=ghp_...        # classic PAT, repo scope → triggers GitHub Actions
# CRON_SECRET=random-string # Vercel Cron auth (/api/treasury-tick every 5 min)
# Optional local: npm run treasury:trigger

# ─── AI SUGGESTIONS (OpenRouter — Admin UI + optional CLI) ─────
# https://openrouter.ai/keys — add same secrets to Supabase platform function:
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=google/gemini-2.0-flash-001   # default; ~$0.001/suggestion
# CLI (key in .env): npm run market:agent:propose | market:agent:settle
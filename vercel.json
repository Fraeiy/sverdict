{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install",
  "env": {
    "VITE_WALLET_URL": "https://sphere.unicity.network",
    "VITE_SITE_URL": "https://sverdict.vercel.app",
    "SITE_URL": "https://sverdict.vercel.app"
  },
  "functions": {
    "api/share.js": {
      "maxDuration": 10
    },
    "api/og.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/s/:code/opengraph-image", "destination": "/api/og?code=:code" },
    { "source": "/s/:code", "destination": "/api/share?code=:code" },
    { "source": "/((?!assets/|api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/s/:code/opengraph-image",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=300, stale-while-revalidate=86400" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}